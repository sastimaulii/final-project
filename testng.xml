<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Automation Suite" parallel="false">

    <!-- Web Tests -->
    <test name="Web Tests">
        <packages>
            <package name="finalproject.automation.runners.WebTestRunner"/>
        </packages>
    </test>

    <!-- API Tests -->
    <test name="API Tests">
        <packages>
            <package name="finalproject.automation.runners.ApiTestRunner"/>
        </packages>
    </test>

    <!-- Optional: Combined Test Runner -->
    <test name="All Tests">
        <classes>
            <class name="org.testng.TestRunner"/>
        </classes>
    </test>

</suite>